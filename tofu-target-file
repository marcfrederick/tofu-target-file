#!/usr/bin/env bash
set -euo pipefail

error() {
    local message="$1"

    echo "$message" >&2
    exit 1
}

find_tofu_resources_in_file() {
    local file_path="$1"

    grep -E '^[[:space:]]*resource[[:space:]]+"[^"]+"[[:space:]]+"[^"]+"' "$file_path" |
        sed -E 's/^[[:space:]]*resource[[:space:]]+"([^"]+)"[[:space:]]+"([^"]+)".*/\1.\2/'
}

main() {
    if [[ $# -lt 1 ]]; then
        error "Usage: $0 <file_path> [<file_path> ...]"
    fi

    for file_path in "$@"; do
        local file_path="$1"
        if [[ ! -f "$file_path" ]]; then
            error "Error: File '$file_path' does not exist."
        fi
        find_tofu_resources_in_file "$file_path"
    done
}

main "$@"
